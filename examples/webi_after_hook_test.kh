# webi_after_hook_test.kh — test suite for after() hooks (webi v1.1.3).
# Run: khan examples/webi_after_hook_test.kh
#
# Tests the after() mechanism itself (registration, ordering, response
# mutation, req["_start_clock"] stamping) using small hooks defined right
# here — not by importing the real `morgos` package, which is a separate
# install and prints to stdout rather than returning something a test
# can assert on. `morgos` is a thin, one-function consumer of exactly
# this mechanism; if after() works correctly, morgos does too. See
# docs/webi.md for a curl-based demonstration of morgos itself.

from webi import webi

fn test_eq(stats, label, actual, expected):
    if actual == expected:
        stats["pass"] = stats["pass"] + 1
        print "  OK   " + label
    else:
        stats["fail"] = stats["fail"] + 1
        print "  FAIL " + label + "  (got: " + str(actual) + ", want: " + str(expected) + ")"
    return stats

fn test_true(stats, label, actual):
    return test_eq(stats, label, actual, true)

let stats = {"pass": 0, "fail": 0}

print "=========================================="
print "webi after() hook test suite"
print "=========================================="

fn fn_home(req):
    return res_html("<h1>hi</h1>")

# ---------------------------------------------------------------------------
print ""
print "-- after() runs post-handler, can read and mutate the response --"

fn hook_add_header(req, res):
    res = res_with_header(res, "X-Seen-By", "hook_add_header")
    return res

let app1 = webi_app()
app1 = route(app1, "GET", "/", fn_home)
app1 = after(app1, hook_add_header)

let res1 = webi_handle(app1, "GET", "/", "", "", "", "127.0.0.1")
stats = test_eq(stats, "handler's own response status is untouched", res1["status"], 200)
stats = test_eq(stats, "after-hook's added header is present", res1["headers"]["X-Seen-By"], "hook_add_header")

# ---------------------------------------------------------------------------
print ""
print "-- multiple after-hooks run in registration order, each seeing the last one's result --"

fn hook_append_a(req, res):
    res["body"] = res["body"] + "-A"
    return res

fn hook_append_b(req, res):
    res["body"] = res["body"] + "-B"
    return res

fn fn_plain(req):
    return res_text("start")

let app2 = webi_app()
app2 = route(app2, "GET", "/plain", fn_plain)
app2 = after(app2, hook_append_a)
app2 = after(app2, hook_append_b)

let res2 = webi_handle(app2, "GET", "/plain", "", "", "", "127.0.0.1")
stats = test_eq(stats, "hooks ran in registration order (A before B)", res2["body"], "start-A-B")

# ---------------------------------------------------------------------------
print ""
print "-- req[\"_start_clock\"] is stamped before dispatch, so hooks can time the request --"

fn hook_check_start_clock(req, res):
    res["_had_start_clock"] = has(req, "_start_clock") and req["_start_clock"] != nil
    return res

let app3 = webi_app()
app3 = route(app3, "GET", "/", fn_home)
app3 = after(app3, hook_check_start_clock)

let res3 = webi_handle(app3, "GET", "/", "", "", "", "127.0.0.1")
stats = test_true(stats, "req[\"_start_clock\"] was set for the hook to read", res3["_had_start_clock"])

# ---------------------------------------------------------------------------
print ""
print "-- an app with no after-hooks registered behaves exactly as before --"

let app4 = webi_app()
app4 = route(app4, "GET", "/", fn_home)
let res4 = webi_handle(app4, "GET", "/", "", "", "", "127.0.0.1")
stats = test_eq(stats, "response unaffected when after_hooks is empty", res4["body"], "<h1>hi</h1>")

# ---------------------------------------------------------------------------
print ""
print "=========================================="
print str(stats["pass"]) + " passed, " + str(stats["fail"]) + " failed"
print "=========================================="

if stats["fail"] > 0:
    exit(1)
