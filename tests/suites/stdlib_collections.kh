# tests/suites/stdlib_collections.kh — the `collections` package.
import "test"
import "collections"

fn is_even(n):
    return n % 2 == 0

fn suite_stdlib_collections():
    let t = test_suite("Stdlib: Collections")

    t = test_eq(t, "reverse_arr", reverse_arr([1, 2, 3])[0], 3)
    t = test_true(t, "arr_contains finds an element", arr_contains([1, 2, 3], 2))
    t = test_false(t, "arr_contains rejects a missing element", arr_contains([1, 2, 3], 9))

    let evens = filter([1, 2, 3, 4, 5, 6], is_even)
    t = test_eq(t, "filter keeps only matching elements", len(evens), 3)

    fn double_it(n):
        return n * 2
    let doubled = map_each([1, 2, 3], double_it)
    t = test_eq(t, "map_each transforms every element", doubled[1], 4)

    fn add(acc, n):
        return acc + n
    t = test_eq(t, "reduce accumulates a value", reduce([1, 2, 3, 4], add, 0), 10)

    let found = find([1, 2, 3, 4], is_even)
    t = test_eq(t, "find returns the first match", found, 2)

    t = test_true(t, "any_match finds at least one match", any_match([1, 3, 4], is_even))
    t = test_false(t, "all_match correctly rejects a mixed array", all_match([1, 2, 3], is_even))
    t = test_true(t, "all_match accepts a fully-matching array", all_match([2, 4, 6], is_even))

    let sorted = sort([3, 1, 2])
    t = test_eq(t, "sort ascending", sorted[0], 1)
    t = test_eq(t, "sort ascending (last)", sorted[2], 3)

    let uniq = unique([1, 2, 2, 3, 3, 3])
    t = test_eq(t, "unique removes duplicates", len(uniq), 3)

    return t
