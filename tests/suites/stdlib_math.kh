# tests/suites/stdlib_math.kh — native math functions + the `math` package.
import "test"
import "math"

fn suite_stdlib_math():
    let t = test_suite("Stdlib: Math")

    # ── native ─────────────────────────────────────────────────────────
    t = test_eq(t, "abs() on negative", abs(-5), 5)
    t = test_eq(t, "abs() on positive", abs(5), 5)
    t = test_eq(t, "round() rounds up at .5", round(2.5), 3)
    t = test_eq(t, "floor()", floor(2.9), 2)
    t = test_eq(t, "ceil()", ceil(2.1), 3)
    t = test_eq(t, "min()", min(3, 7), 3)
    t = test_eq(t, "max()", max(3, 7), 7)
    t = test_eq(t, "pow()", pow(2, 10), 1024)
    t = test_eq(t, "sqrt()", sqrt(144), 12)

    let r = random()
    t = test_true(t, "random() is within [0, 1)", r >= 0 and r < 1)

    # ── `math` package ─────────────────────────────────────────────────
    t = test_eq(t, "math_gcd", math_gcd(12, 18), 6)
    t = test_eq(t, "math_lcm", math_lcm(4, 6), 12)
    t = test_true(t, "math_is_prime(17) is true", math_is_prime(17))
    t = test_false(t, "math_is_prime(18) is false", math_is_prime(18))
    t = test_eq(t, "math_factorial(5)", math_factorial(5), 120)
    t = test_eq(t, "math_sum", math_sum([1, 2, 3, 4]), 10)
    t = test_eq(t, "math_mean", math_mean([2, 4, 6]), 4)
    t = test_eq(t, "math_clamp within range", math_clamp(5, 0, 10), 5)
    t = test_eq(t, "math_clamp above range", math_clamp(15, 0, 10), 10)
    t = test_eq(t, "math_clamp below range", math_clamp(-5, 0, 10), 0)
    t = test_eq(t, "lerp midpoint", lerp(0, 10, 0.5), 5)

    let v = vec2(3, 4)
    t = test_eq(t, "vec2_len (3-4-5 triangle)", vec2_len(v), 5)

    return t
