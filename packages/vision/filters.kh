# ---------------------------------------------------------------------------
# edges_file(input_path, output_path) -> bool
# Sobel gradient-magnitude edge detection. Output is single-channel
# (bright = strong edge).
# ---------------------------------------------------------------------------
fn edges_file(input_path, output_path):
    let img = vision_load(_vision_resolve(input_path))
    if img == nil:
        return false
    let edges = vision_edges_sobel(img)
    let ok = vision_save(edges, _vision_resolve(output_path))
    vision_free(img)
    vision_free(edges)
    return ok
