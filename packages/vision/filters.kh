# vision/filters.kh — convolution-based filters. Needs core.kh.

# ---------------------------------------------------------------------------
# blur_file(input_path, output_path, radius) -> bool
# Box blur — fast, slightly blocky.
# ---------------------------------------------------------------------------
fn blur_file(input_path, output_path, radius):
    let img = vision_load(_vision_resolve(input_path))
    if img == nil:
        return false
    let blurred = vision_blur_box(img, radius)
    let ok = vision_save(blurred, _vision_resolve(output_path))
    vision_free(img)
    vision_free(blurred)
    return ok

# ---------------------------------------------------------------------------
# blur_gaussian_file(input_path, output_path, radius) -> bool
# Gaussian blur — smoother falloff than the box blur, costs a bit more.
# ---------------------------------------------------------------------------
fn blur_gaussian_file(input_path, output_path, radius):
    let img = vision_load(_vision_resolve(input_path))
    if img == nil:
        return false
    let blurred = vision_blur_gaussian(img, radius)
    let ok = vision_save(blurred, _vision_resolve(output_path))
    vision_free(img)
    vision_free(blurred)
    return ok

# ---------------------------------------------------------------------------
# sharpen_file(input_path, output_path) -> bool
# ---------------------------------------------------------------------------
fn sharpen_file(input_path, output_path):
    let img = vision_load(_vision_resolve(input_path))
