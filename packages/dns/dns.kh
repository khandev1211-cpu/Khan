# Khan DNS Package (DNS-over-HTTPS)
# Usage: import "dns"

import "requests"

fn dns_lookup(domain):
    let url = "https://dns.google/resolve?name=" + domain
    # Use requests.get for auto-attach json
    let res = get(url)
    if res["success"]:
        let data = json_decode(res["body"])
        if data != nil:
            if has(data, "Answer"):
                let ans = data["Answer"]
                if len(ans) > 0:
                    return ans[0]["data"]
    return nil
